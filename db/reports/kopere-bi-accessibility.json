    {
      "refkey": "theme_degrade_acc_blk_summary",
      "type": "block-1",
      "sequence": 2,
      "elements": [
        {
          "title": "lang::accessibilityreport_summary_by_student::theme_degrade",
          "refkey": "theme_degrade_acc_summary",
          "block_num": 1,
          "type": "table",
          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT u.id,\n       u.firstname,\n       u.lastname,\n       u.email,\n       COALESCE(SUM(CASE WHEN l.action = 'vlibras_tab_click' THEN 1 ELSE 0 END), 0) AS vlibras_clicks,\n       COALESCE(SUM(CASE WHEN l.action = 'toolbar_open' THEN 1 ELSE 0 END), 0) AS toolbar_opens,\n       COALESCE(SUM(CASE WHEN l.action = 'toolbar_item' AND l.status = 'enabled' THEN 1 ELSE 0 END), 0) AS activated_items,\n       COALESCE(SUM(CASE WHEN l.action = 'toolbar_item' AND l.status = 'disabled' THEN 1 ELSE 0 END), 0) AS deactivated_items,\n       MAX(l.timecreated) AS last_action,\n       COALESCE(lastlog.activeitems, '') AS current_active_items\nFROM mdl_user u\n       JOIN mdl_theme_degrade_accesslog l ON l.userid = u.id\n       LEFT JOIN mdl_theme_degrade_accesslog lastlog ON lastlog.id = (\n           SELECT MAX(l2.id)\n             FROM mdl_theme_degrade_accesslog l2\n            WHERE l2.userid = u.id\n              AND l2.action IN ('toolbar_item', 'toolbar_open', 'toolbar_reset')\n       )\nWHERE u.deleted = 0\nGROUP BY u.id, u.firstname, u.lastname, u.email, lastlog.activeitems\nORDER BY last_action DESC",
          "cache": "15m",
          "reload": "none",
          "info": {
            "column": {
              "id": {
                "key": "id",
                "title": "#",
                "type": "number",
                "mustache": ""
