    {
      "refkey": "theme_degrade_acc_blk_current",
      "type": "block-1",
      "sequence": 3,
      "elements": [
        {
          "title": "lang::accessibilityreport_active_items_by_student::theme_degrade",
          "refkey": "theme_degrade_acc_current",
          "block_num": 1,
          "type": "table",
          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT u.id,\n       u.firstname,\n       u.lastname,\n       u.email,\n       COALESCE(lastlog.activeitems, '') AS active_items,\n       lastlog.timecreated AS last_update,\n       lastlog.pageurl\nFROM mdl_theme_degrade_accesslog lastlog\n       JOIN (\n           SELECT userid, MAX(id) AS lastid\n             FROM mdl_theme_degrade_accesslog\n            WHERE action IN ('toolbar_item', 'toolbar_open', 'toolbar_reset')\n            GROUP BY userid\n       ) latest ON latest.lastid = lastlog.id\n       JOIN mdl_user u ON u.id = lastlog.userid\nWHERE u.deleted = 0\nORDER BY lastlog.timecreated DESC",
          "cache": "15m",
          "reload": "none",
          "info": {
